;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="00 Devilish Aces (Copy)"
run/main_scene="uid://bopk46nk2blun"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GlobalValues="*uid://dasfre13k1g42"

[debug_draw_3d]

settings/addon_root_folder="res://addons/debug_draw_3d"

[display]

window/size/viewport_width=320
window/size/viewport_height=240
window/size/mode=2
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/GPUTrail-main/plugin.cfg")

[global_group]

Player=""
MainCamera=""
Target=""
PlayerController=""

